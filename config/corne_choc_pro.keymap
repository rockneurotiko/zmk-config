/*
 * Corne Choc Pro — thin wrapper around base.keymap.
 *
 * Physical layout: 5-column, encoders on right half only.
 *
 * The 5-col transform has 40 key positions:
 *   Row 0:  5 left  + (encL encR) + 5 right  = 12
 *   Row 1:  5 left  + (encL encR) + 5 right  = 12
 *   Row 2:  5 left  + 5 right                = 10
 *   Thumb:  3 left  + 3 right                =  6
 *
 * Encoder positions 5,17 (left) → &none (no left encoders).
 * Encoder positions 6,18 (right) → encoder press buttons.
 * Encoder rotation is handled by sensor-bindings (right_ex1 & right_ex2).
 *
 * Architecture follows github.com/urob/zmk-config.
 */

#define CONFIG_WIRELESS

/* ── Adapt the 34-key base layout to the 40-position 5-col grid ──────────
 *
 * base.keymap calls ZMK_BASE_LAYER(name, LT, RT, LM, RM, LB, RB, LH, RH)
 * where LT/RT/LM/RM/LB/RB are 5 keys each and LH/RH are 3 thumbs each.
 * We splice in the encoder-area keys between left and right halves.
 * ──────────────────────────────────────────────────────────────────────── */

#define ZMK_BASE_LAYER(name, LT, RT, LM, RM, LB, RB, LH, RH)                \
    ZMK_LAYER(                                                                 \
        name,                                                                  \
        LT &none &kp C_MUTE RT                                                \
        LM &none &kp C_PP   RM                                                \
        LB                  RB                                                 \
        LH                  RH                                                 \
    )

/* Use the 36-key position labels (5 cols × 3 rows × 2 sides + 6 thumbs). */
#include "zmk-helpers/key-labels/36.h"

/* Pull in the shared base keymap. */
#include "base.keymap"

/* ── Physical layout selection ─────────────────────────────────────────── */

/ {
    chosen {
        zmk,physical-layout = &five_col_layout;
    };
};

/* ── Encoders ──────────────────────────────────────────────────────────── */

&right_ex1_encoder {
    status = "okay";
};

&right_ex2_encoder {
    status = "okay";
};

/* Overlay sensor-bindings onto layers generated by base.keymap.
 * Sensor order: left_ex1, left_ex2, right_ex1, right_ex2.
 * Left placeholders required even though not installed. */

/ {
    keymap {
        layer_Base {
            sensor-bindings =
                <&inc_dec_kp C_VOL_DN C_VOL_UP>,
                <&inc_dec_kp PG_UP PG_DN>,
                <&inc_dec_kp C_VOL_DN C_VOL_UP>,    /* right_ex1: volume */
                <&inc_dec_kp C_BRI_DN C_BRI_UP>     /* right_ex2: brightness */
            ;
        };
        layer_Nav {
            sensor-bindings =
                <&inc_dec_kp C_VOL_DN C_VOL_UP>,
                <&inc_dec_kp PG_UP PG_DN>,
                <&inc_dec_kp PG_UP PG_DN>,          /* right_ex1: page up/down */
                <&inc_dec_kp C_VOL_DN C_VOL_UP>     /* right_ex2: volume */
            ;
        };
        layer_Fn {
            sensor-bindings =
                <&inc_dec_kp C_VOL_DN C_VOL_UP>,
                <&inc_dec_kp PG_UP PG_DN>,
                <&inc_dec_kp C_PREV C_NEXT>,        /* right_ex1: prev/next track */
                <&inc_dec_kp C_VOL_DN C_VOL_UP>     /* right_ex2: volume */
            ;
        };
    };
};

/* vim: set ft=c tw=146: */
